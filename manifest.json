{
  "manifest_version": 3,
  "name": "IP Whitelist Blocker",
  "version": "1.0",
  "description": "Blocks network traffic when your IP is not whitelisted",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://api.ipify.org/",
    "http://ip-api.com/",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
