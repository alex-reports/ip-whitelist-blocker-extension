{
  "manifest_version": 3,
  "name": "IP Whitelist Blocker",
  "version": "1.1",
  "description": "Blocks network traffic when your IP is not whitelisted. Includes geo info, VPN detection, and IP history.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "webNavigation",
    "tabs",
    "notifications",
    "action"
  ],
  "host_permissions": [
    "https://api.ipify.org/",
    "https://api64.ipify.org/",
    "https://ipwho.is/",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
